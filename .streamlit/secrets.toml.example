# Streamlit secrets 예시 — 이 파일을 `.streamlit/secrets.toml`로 복사 후 값을 채우세요.
# secrets.toml 은 git에 올리지 마세요.

# 앱 접속 비밀번호 (비우면 로컬에서 비밀번호 없이 입장)
COMPOSE_APP_PASSWORD = "change-me"

# Google Drive — images 루트 폴더 ID
# 폴더 URL: https://drive.google.com/drive/folders/XXXXXXXX
# → XXXXXXXX 부분
GDRIVE_FOLDER_ID = "YOUR_IMAGES_FOLDER_ID"

# 서비스 계정 JSON 전체 (한 줄이 아니라 toml 인라인 테이블/문자열)
# 방법 A: JSON을 삼중따옴표 문자열로
GDRIVE_SERVICE_ACCOUNT_JSON = """
{
  "type": "service_account",
  "project_id": "...",
  "private_key_id": "...",
  "private_key": "-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n",
  "client_email": "phqm-compose@....iam.gserviceaccount.com",
  "client_id": "...",
  "token_uri": "https://oauth2.googleapis.com/token"
}
"""

# Streamlit Cloud 읽기전용 대응 (기본도 /tmp 이지만 명시 권장)
COMPOSE_CACHE_DIR = "/tmp/phqm_drive_images"
